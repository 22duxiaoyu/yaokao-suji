# Local PostgreSQL or Supabase pooled connection string.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/yaokao_suji
DATABASE_POOL_MAX=5

AI_PROVIDER=deepseek
AI_API_KEY=
AI_MODEL=deepseek-v4-flash
AI_BASE_URL=https://api.deepseek.com

# Portfolio demo safety limits.
PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
DEMO_AI_DAILY_LIMIT=20
DEMO_MAX_GENERATED_CARDS=6
DEMO_MAX_UPLOAD_MB=4
NEXT_PUBLIC_DEMO_MAX_UPLOAD_MB=4

EMBEDDING_PROVIDER=aliyun-bailian
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4

# Leave Supabase values empty to keep local file storage in ./uploads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=materials

UPLOAD_DIR=./uploads
